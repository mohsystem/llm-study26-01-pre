<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <property name="USER_PROMPT_LOG_FILE" value="${USER_PROMPT_LOG_FILE:-user-prompt.log}"/>

    <appender name="USER_PROMPT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${USER_PROMPT_LOG_FILE}</file>
        <append>true</append>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${USER_PROMPT_LOG_FILE}.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>200MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="USER_PROMPT" level="INFO" additivity="false">
        <appender-ref ref="USER_PROMPT_FILE"/>
    </logger>
</configuration>

